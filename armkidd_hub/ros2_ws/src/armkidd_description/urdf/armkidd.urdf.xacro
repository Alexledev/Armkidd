<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="armkidd">

    <xacro:arg name="is_sim" default="false"/>

    <!-- <xacro:arg name="camera_x_offset" default="-0.5"/>
    <xacro:arg name="camera_y_offset" default="-1.3"/>
    <xacro:arg name="camera_z_offset" default="2.8"/> -->


    <!--INCLUDES-->
    <xacro:include filename="$(find armkidd_description)/urdf/armkidd_gazebo.xacro"/>
    <xacro:include filename="$(find armkidd_description)/urdf/armkidd_control.xacro"/>
    <xacro:include filename="$(find armkidd_description)/urdf/armkidd_cam.urdf.xacro"/>

    <!-- DEFINITIONS-->
    <xacro:property name="PI" value="3.14159"/>
    <xacro:property name="effort" value="30.0"/>
    <xacro:property name="velocity" value="10.0"/>

    <xacro:macro name="default_inertial" params="mass">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${mass}"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0"
                      iyy="1.0" iyz="0.0"
                      izz="1.0"/>
        </inertial>
    </xacro:macro>

    <!--LINKS-->
    <link name="world"/>

    <link name="base_link">
        <xacro:default_inertial mass="10.0"/>
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_Base.stl" scale="10 10 10"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
                <ambient>0.2 0.2 0.2 1</ambient>
                <diffuse>0.2 0.2 0.2 1</diffuse>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_Base.stl" scale="10 10 10"/>
            </geometry>
        </collision>
    </link>

    <link name="base_link2">
        <xacro:default_inertial mass="10.0"/>
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <cylinder radius="0.7" length="0.5"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
                <ambient>0.2 0.2 0.2 1</ambient>
                <diffuse>0.2 0.2 0.2 1</diffuse>
            </material>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.7" length="0.5"/>
            </geometry>
        </collision>
    </link>

    <link name="base_servo">
        <xacro:default_inertial mass="0.05"/>
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_Base_Servo1.stl" scale="10 10 10"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
                <ambient>0.2 0.2 0.2 1</ambient>
                <diffuse>0.2 0.2 0.2 1</diffuse>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_Base_Servo1.stl" scale="10 10 10"/>
            </geometry>
        </collision>
    </link>

    <link name="shoulder_servo">
        <xacro:default_inertial mass="0.05"/>
        <visual>
            <origin rpy="0 0 0" xyz="-0.13 0 0"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_Base_Servo2.stl" scale="10 10 10"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
                <ambient>0.2 0.2 0.2 1</ambient>
                <diffuse>0.2 0.2 0.2 1</diffuse>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="-0.13 0 0"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_Base_Servo2.stl" scale="10 10 10"/>
            </geometry>
        </collision>
    </link>

    <link name="lower_arm">
        <xacro:default_inertial mass="0.02"/>
        <visual>
            <origin rpy="0 0 0" xyz="-0.125 0 -0.85"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_LowerArm.stl" scale="10 10 10"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
                <ambient>0.2 0.2 0.2 1</ambient>
                <diffuse>0.2 0.2 0.2 1</diffuse>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="-0.125 0 -0.85"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_LowerArm.stl" scale="10 10 10"/>
            </geometry>
        </collision>
    </link>

    <link name="elbow_servo">
        <xacro:default_inertial mass="0.05"/>
        <visual>
            <origin rpy="0 0 0" xyz="-0.125 0 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_Elbow_Servo.stl" scale="10 10 10"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
                <ambient>0.2 0.2 0.2 1</ambient>
                <diffuse>0.2 0.2 0.2 1</diffuse>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="-0.125 0 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_Elbow_Servo.stl" scale="10 10 10"/>
            </geometry>
        </collision>
    </link>

    <link name="fore_arm">
        <xacro:default_inertial mass="0.1"/>
        <visual>
            <origin rpy="0 0 0" xyz="-0.12 0 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_UpperArm.stl" scale="10 10 10"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
                <ambient>0.2 0.2 0.2 1</ambient>
                <diffuse>0.2 0.2 0.2 1</diffuse>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="-0.12 0 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_UpperArm.stl" scale="10 10 10"/>
            </geometry>
        </collision>
    </link>

    <link name="wrist_servo">
        <xacro:default_inertial mass="0.05"/>
        <visual>
            <origin rpy="0 0 0" xyz="-0.12 0 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_Wrist_Servo.stl" scale="10 10 10"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
                <ambient>0.2 0.2 0.2 1</ambient>
                <diffuse>0.2 0.2 0.2 1</diffuse>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="-0.12 0 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_Wrist_Servo.stl" scale="10 10 10"/>
            </geometry>
        </collision>
    </link>

    <link name="wrist_extension">
        <xacro:default_inertial mass="0.01"/>
        <visual>
            <origin rpy="0 0 0" xyz="-1.4 0 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_WristExtend.stl" scale="10 10 10"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
                <ambient>0.2 0.2 0.2 1</ambient>
                <diffuse>0.2 0.2 0.2 1</diffuse>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="-1.4 0 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_WristExtend.stl" scale="10 10 10"/>
            </geometry>
        </collision>
    </link>

    <link name="wristX_servo">
        <xacro:default_inertial mass="0.05"/>
        <visual>
            <origin rpy="0 0 0" xyz="-1.91 0 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_WristX_Servo.stl" scale="10 10 10"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
                <ambient>0.2 0.2 0.2 1</ambient>
                <diffuse>0.2 0.2 0.2 1</diffuse>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="-1.91 0 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_WristX_Servo.stl" scale="10 10 10"/>
            </geometry>
        </collision>
    </link>

    <link name="arm_hand">
        <xacro:default_inertial mass="0.01"/>
        <visual>
            <origin rpy="0 0 0" xyz="-2.15 0 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_ArmHand.stl" scale="10 10 10"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
                <ambient>0.2 0.2 0.2 1</ambient>
                <diffuse>0.2 0.2 0.2 1</diffuse>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="-2.15 0 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_ArmHand.stl" scale="10 10 10"/>
            </geometry>
        </collision>
    </link>

    <link name="end_eff"/>

    <!-- <link name="gripper_right">
        <xacro:default_inertial mass="0.01"/>
        <visual>
            <origin rpy="0 0 0" xyz="-2.15 0.165 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_Gripper1.stl" scale="10 10 10"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
                <ambient>0.2 0.2 0.2 1</ambient>
                <diffuse>0.2 0.2 0.2 1</diffuse>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="-2.15 0.165 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_Gripper1.stl" scale="10 10 10"/>
            </geometry>
        </collision>
    </link>

    <link name="gripper_left">
        <xacro:default_inertial mass="0.01"/>
        <visual>
            <origin rpy="0 0 0" xyz="-2.15 -0.14 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_Gripper2.stl" scale="10 10 10"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
                <ambient>0.2 0.2 0.2 1</ambient>
                <diffuse>0.2 0.2 0.2 1</diffuse>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="-2.15 -0.14 -1.9"/>
            <geometry>
                <mesh filename="file://$(find armkidd_description)/meshes/ARM_Gripper2.stl" scale="10 10 10"/>
            </geometry>
        </collision>
    </link> -->

    <link name="gripper_right">
        <xacro:default_inertial mass="0.01"/>
        <visual>
            <origin rpy="0 0 0" xyz="0.2 0 0"/>
            <geometry>
                <box size="0.8 0.1 0.05"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
            </material>
        </visual>

        <collision>
            <origin rpy="0 0 0" xyz="0.2 0 0"/>
            <geometry>
                <box size="0.8 0.1 0.05"/>
            </geometry>
        </collision>
    </link>

    <link name="gripper_left">
        <xacro:default_inertial mass="0.01"/>
        <visual>
            <origin rpy="0 0 0" xyz="0.2 0 0"/>
            <geometry>
                <box size="0.8 0.1 0.05"/>
            </geometry>

            <material name="LightGrey">
                <color rgba="0.2 0.2 0.2 1.0"/>
            </material>
        </visual>

        <collision>
            <origin rpy="0 0 0" xyz="0.2 0 0"/>
            <geometry>
                <box size="0.8 0.1 0.05"/>
            </geometry>
        </collision>
    </link>

    <!--JOINTS-->

    <joint name="virtual_joint" type="fixed">
        <parent link="world"/>
        <child link="base_link"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>    
    </joint>

    <joint name="arm_extension" type="fixed">
        <parent link="base_link"/>
        <child link="base_link2"/>
        <axis xyz = "0 0 1"/>
        <origin rpy="0 0 0" xyz="0 0 0.35"/>        
    </joint>

    <joint name="arm_base" type="fixed">
        <parent link="base_link"/>
        <child link="base_servo"/>
        <axis xyz = "0 0 1"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>        
    </joint>

    <joint name="joint_1" type="revolute">
        <parent link="base_servo"/>
        <child link="shoulder_servo"/>
        <axis xyz = "0 0 1"/>
        <origin rpy="0 0 0" xyz="0.13 0 0"/>        
        <limit lower="-${PI/2}" upper="${PI/2}" effort="${effort}" velocity="${velocity}"/>
    </joint>

    <joint name="joint_2" type="revolute">
        <parent link="shoulder_servo"/>
        <child link="lower_arm"/>
        <axis xyz = "0 1 0"/>
        <origin rpy="0 0 0" xyz="0 0 0.85"/>        
        <limit lower="-${PI/2}" upper="${PI/2}" effort="${effort}" velocity="${velocity}"/>
    </joint>

    <joint name="joint_3" type="revolute">
        <parent link="lower_arm"/>
        <child link="elbow_servo"/>
        <axis xyz = "0 1 0"/>
        <origin rpy="0 0 0" xyz="0 0 1.04"/>        
        <limit lower="-${PI/2}" upper="${PI/2}" effort="${effort}" velocity="${velocity}"/>
    </joint>

    <joint name="forearm" type="fixed">
        <parent link="elbow_servo"/>
        <child link="fore_arm"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>        
    </joint>

    <joint name="wrist" type="fixed">
        <parent link="fore_arm"/>
        <child link="wrist_servo"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>        
    </joint>

    <joint name="joint_4" type="revolute">
        <parent link="wrist_servo"/>
        <child link="wrist_extension"/>
        <axis xyz = "0 1 0"/>
        <origin rpy="0 0 0" xyz="1.28 0 0"/>        
        <limit lower="-${PI/2}" upper="${PI/2}" effort="${effort}" velocity="${velocity}"/>
    </joint>

    <joint name="wristXServo" type="fixed">
        <parent link="wrist_extension"/>
        <child link="wristX_servo"/>
        <origin rpy="0 0 0" xyz="0.51 -0.02 0"/>        
    </joint>

    <joint name="joint_5" type="revolute">
        <parent link="wristX_servo"/>
        <child link="arm_hand"/>
        <axis xyz = "1 0 0"/>
        <origin rpy="0 0 0" xyz="0.72 -0.005 0"/>   
        <limit lower="-${PI/2}" upper="${PI/2}" effort="${effort}" velocity="${velocity}"/>     
    </joint>

    <joint name="end_effector" type="fixed">
        <parent link="arm_hand"/>
        <child link="end_eff"/>
        <origin rpy="0 0 0" xyz="1.1 0 0"/>
    </joint>

    <joint name="joint_6" type="prismatic">
        <parent link="arm_hand"/>
        <child link="gripper_right"/>
        <axis xyz="0 -1 0"/>

        <origin rpy="0 0 0" xyz="0 -0.145 0"/>

        <limit lower="0" upper="0.15" effort="${effort}" velocity="${velocity}"/>
    </joint>


    <joint name="joint_7" type="prismatic">
        <parent link="arm_hand"/>
        <child link="gripper_left"/>
        <axis xyz="0 1 0"/>

        <origin rpy="0 0 0" xyz="0 0.120 0"/>

        <limit lower="0" upper="0.15" effort="${effort}" velocity="${velocity}"/>

        <mimic joint="joint_6" multiplier="1"/>
    </joint>

    <!--0.75-->
